# ─── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=custom-openai-compatible
LLM_BASE_URL=http://your-llm-server/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-name

# ─── FastAPI Server ────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
