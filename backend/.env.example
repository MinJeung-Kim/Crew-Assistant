# ─── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=custom-openai-compatible
LLM_BASE_URL=http://your-llm-server/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-name

# ─── FastAPI Server ────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── CrewAI ───────────────────────────────────────────────────────────────────
CREWAI_ENABLED=true
# Optional override. Leave empty to auto-map to openai/<LLM_MODEL>.
CREWAI_MODEL=
CREWAI_WEB_SEARCH_RESULTS=6

# ─── RAG (Company Knowledge) ─────────────────────────────────────────────────
RAG_ENABLED=true
RAG_STORAGE_PATH=./data/knowledge
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=4
RAG_MAX_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
RAG_MAX_UPLOAD_MB=20
